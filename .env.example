# ==========================================
# 에이전트 로컬 테스트 및 배포를 위한 환경 변수 템플릿
# ==========================================

# 1. 필수 설정 (사용자 환경에 맞게 변경하세요)
GOOGLE_CLOUD_PROJECT=your-project-id-here

# 2. 모델 엔드포인트 우회 설정 (변경 금지)
# Agent Engine 인프라(us-central1 등)와 무관하게, 모델 추론은 항상 global 엔드포인트를 타도록 강제합니다.
GOOGLE_CLOUD_LOCATION=global

# 3. 엔터프라이즈 모니터링 (Trace/Log) 및 데이터 캡처 (선택 사항)
GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=true
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true
